# 龙虾出行开放平台 - 环境变量示例
# 复制本文件为 .env.local 并填入真实值（.env.local 已被 gitignore，不会提交）

# 【必填】龙虾出行 API Token（服务端使用，切勿暴露给前端）
LONGXA_API_TOKEN=rdak_live_xxxxxxxxxxxxxxxx

# 【可选】API 网关基础域名（默认 https://api.longxiachuxing.com）
# LONGXA_API_BASE=https://api.longxiachuxing.com

# 【可选】上游请求超时（毫秒，默认 30000）
# LONGXA_API_TIMEOUT=30000
